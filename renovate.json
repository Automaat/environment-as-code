{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "reviewers": ["Automaat"],
  "automerge": true,
  "automergeStrategy": "squash",
  "platformAutomerge": false,
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["* 0-5 * * 1"]
  }
}
